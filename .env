# Copie este arquivo para ".env" e preencha com os seus dados reais.
# O arquivo ".env" NUNCA deve ser enviado para o Git (já está no .gitignore).

# Conta de e-mail que vai ENVIAR a notificação (ex: uma conta do Gmail).
EMAIL_HOST_USER=pietro.s.thor@gmail.com

# Senha de app gerada pelo Google (NÃO é a senha normal da sua conta).
# Veja como gerar em: https://myaccount.google.com/apppasswords
EMAIL_HOST_PASSWORD=pkrz kkpe tben mbed

# E-mail que vai RECEBER as mensagens do formulário de contato.
# Pode ser o mesmo e-mail de cima, ou outro (ex: o e-mail que você já
# acessa todo day).
CONTACT_EMAIL=pietro.s.thor@gmail.com

# Só precisa trocar se você usar outro provedor que não seja Gmail.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
